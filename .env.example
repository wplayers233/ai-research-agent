# ===== LLM API (必填) =====
# 智谱 GLM API Key — 从 https://open.bigmodel.cn 获取
GLM_API_KEY="your-glm-api-key"
# 模型: deepseek-v4-flash (推荐) / glm-4.7
LLM_MODEL_ID="deepseek-v4-flash"
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# DeepSeek API Key — 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# ===== Embedding (必填) =====
EMBEDDING_MODEL_ID="embedding-3"
EMBEDDING_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# ===== Search APIs (至少填一个) =====
# Brave Search API Key — 从 https://brave.com/search/api/ 获取
BRAVE_API_KEY="your-brave-api-key"
# Tavily Search API Key — 从 https://tavily.com 获取
TAVILY_API_KEY="your-tavily-api-key"

# ===== 学术搜索 (可选) =====
# HuggingFace Token — 从 https://huggingface.co/settings/tokens 获取
HF_TOKEN="your-hf-token"

# ===== GitHub (可选) =====
GITHUB_TOKEN="your-github-token"

# ===== 数据目录 =====
ARXIV_DOWNLOAD_DIR="data/downloads"
RAG_DATA_DIR="data/rag"

# ===== 网络代理 (可选) =====
# http_proxy="http://127.0.0.1:7897"
# https_proxy="http://127.0.0.1:7897"
